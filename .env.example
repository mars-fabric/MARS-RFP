# =============================================================================
# MARS-RFP Environment Configuration
# =============================================================================

# =============================================================================
# API Keys
# =============================================================================

# OpenAI API Key (required for GPT models)
OPENAI_API_KEY=

# Anthropic API Key (optional, for Claude models)
ANTHROPIC_API_KEY=

# Google Gemini API Key (optional)
GEMINI_API_KEY=

# Perplexity API Key (optional)
PERPLEXITY_API_KEY=

# Azure OpenAI (if using Azure instead of OpenAI directly)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=

# =============================================================================
# Work Directory Configuration
# =============================================================================

# Root directory for all task outputs, logs, and session data
# Directory structure:
#   {RFP_DEFAULT_WORK_DIR}/
#   └── sessions/
#       └── {session_id}/
#           ├── session.log              # Complete audit trail
#           └── tasks/
#               └── {task_id}/
#                   ├── logs/
#                   │   ├── run.log      # Infrastructure events
#                   │   └── console_output.log
#                   ├── cost/            # Cost reports
#                   ├── data/            # Task data
#                   └── ...
RFP_DEFAULT_WORK_DIR="~/Desktop/cmbdir/rfp"

# Frontend work directory (must have NEXT_PUBLIC_ prefix for Next.js)
# Should match RFP_DEFAULT_WORK_DIR to ensure consistency
NEXT_PUBLIC_RFP_WORK_DIR="~/Desktop/cmbdir/rfp"

# =============================================================================
# Backend Configuration
# =============================================================================

# Backend port
PORT=8011

# Application title
RFP_APP_TITLE="MARS - RFP Proposal"

# Application version
RFP_APP_VERSION="1.0.0"

# CORS allowed origins (comma-separated)
RFP_CORS_ORIGINS="http://localhost:3011,http://localhost:3012,http://localhost:3013"

# Maximum file upload size (MB)
RFP_MAX_FILE_SIZE_MB="50"

# Debug mode (true/false)
RFP_DEBUG="false"

# =============================================================================
# Frontend Configuration
# =============================================================================

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:8011

# WebSocket URL
NEXT_PUBLIC_WS_URL=ws://localhost:8011

# Enable debug mode
NEXT_PUBLIC_DEBUG=false

# =============================================================================
# Logging Configuration
# =============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL="INFO"

# Use JSON format for console output (true/false)
LOG_JSON="false"

# Backend system log file location (optional - overrides default)
# Default: {RFP_DEFAULT_WORK_DIR}/logs/backend.log
# LOG_FILE="/custom/path/to/backend.log"

# =============================================================================
# Database Configuration
# =============================================================================

# Database URL
DATABASE_URL=postgresql://mars:mars_dev@localhost:5432/mars_rfp
