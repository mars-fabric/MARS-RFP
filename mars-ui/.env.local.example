# MARS-RFP Environment Variables
# Copy this file to .env.local and fill in your values

# Backend API URL
# For local development: http://localhost:8011
# For remote access: http://<server-ip>:8011 (replace with actual server IP)
NEXT_PUBLIC_API_URL=http://localhost:8011

# WebSocket URL
# For local development: ws://localhost:8011
# For remote access: ws://<server-ip>:8011 (replace with actual server IP)
NEXT_PUBLIC_WS_URL=ws://localhost:8011

# Work directory for task outputs and logs
# Should match RFP_DEFAULT_WORK_DIR in backend .env
# Default: ~/Desktop/cmbdir/rfp
NEXT_PUBLIC_RFP_WORK_DIR=~/Desktop/cmbdir/rfp

# Optional: Enable debug mode
NEXT_PUBLIC_DEBUG=false
